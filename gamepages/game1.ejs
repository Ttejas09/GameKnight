    <script>
        function sound() {
            const bgsound = document.getElementById("bg-vid");
            const mutebtn = document.getElementById("mutebtn");


            if (bgsound.muted == true) {
                bgsound.muted = false;
                mutebtn.innerHTML = `<img src="media/do-not-make-a-loud-noise-no-speaker-no-sound-icon-free-vector.jpg" id="img1">`;


            }
            else {
                bgsound.muted = true;
                mutebtn.innerHTML = `<img src="media/1818835-200.png" id="img1">`;
            }
        }

        window.addEventListener("scroll", function () {

            let scrollY = window.scrollY;
            let blurAmount = Math.min(scrollY / 80, 10);

            document.getElementById("bg-vid").style.filter =
                "blur(" + blurAmount + "px)";

        });

        document.addEventListener("DOMContentLoaded", function () {
            const observerOptions = {
                root: null,
                rootMargin: "0px",
                threshold: 0.2 // Triggers when 10% of the element is visible
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        // Add the class that triggers the animation
                        entry.target.classList.add("in-view");

                        // Stop observing once the animation has triggered
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            // Target the elements we want to animate
            const animatedElements = document.querySelectorAll('.right, .linktable, .official-download ,.system-req ,.sim-games');

            animatedElements.forEach(el => {
                observer.observe(el);
            });
        });

    </script>

